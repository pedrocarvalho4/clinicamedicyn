name: Editorial Check

on:
  workflow_dispatch:
  schedule:
    - cron: '15 8 */5 * *'

permissions:
  contents: read
  issues: write

jobs:
  check-editorial-date:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v5

      - name: Check editorial topics for next 10 days
        id: editorial
        run: |
          python - <<'PY'
          import os
          import json
          from datetime import datetime, timedelta
          from zoneinfo import ZoneInfo

          tz = ZoneInfo("Europe/Lisbon")
          today = datetime.now(tz).date()

          events_file = "src/data/editorial-dates.json"

          with open(events_file, "r", encoding="utf-8") as f:
              events = json.load(f)

          upcoming_matches = []

          for event in events:
              event_year = event.get("year")
              month = event.get("month")
              day = event.get("day")
              duration_days = event.get("duration_days")
              title = event.get("title", "Sem título")

              if not month or not day:
                  continue

              # Campanhas/mensalidades com duração definida
              if duration_days:
                  if event_year and event_year != today.year:
                      continue

                  start_date = datetime(today.year, month, day, tzinfo=tz).date()
                  if event_year:
                      start_date = datetime(event_year, month, day, tzinfo=tz).date()

                  end_date = start_date + timedelta(days=duration_days - 1)

                  # Se a campanha ainda não começou, mas começa nos próximos 10 dias
                  if today <= start_date <= today + timedelta(days=10):
                      upcoming_matches.append({
                          **event,
                          "event_date": start_date.isoformat(),
                          "days_until": (start_date - today).days,
                          "kind": "campaign_start"
                      })
                      continue

                  # Se a campanha já está a decorrer
                  if start_date <= today <= end_date:
                      upcoming_matches.append({
                          **event,
                          "event_date": start_date.isoformat(),
                          "days_until": 0,
                          "kind": "campaign_active"
                      })
                      continue

                  continue

              # Evento anual fixo ou com ano específico
              if event_year:
                  event_date = datetime(event_year, month, day, tzinfo=tz).date()

                  if event_date < today:
                      continue
              else:
                  event_date = datetime(today.year, month, day, tzinfo=tz).date()

                  if event_date < today:
                      event_date = datetime(today.year + 1, month, day, tzinfo=tz).date()

              days_until = (event_date - today).days

              if 0 <= days_until <= 10:
                  upcoming_matches.append({
                      **event,
                      "event_date": event_date.isoformat(),
                      "days_until": days_until,
                      "kind": "day"
                  })

          upcoming_matches.sort(key=lambda x: (x["days_until"], x.get("title", "")))

          output_path = os.environ["GITHUB_OUTPUT"]

          if upcoming_matches:
              top = upcoming_matches[0]

              category = top.get("category", "general")
              specialties = ", ".join(top.get("specialties", []))
              source_name = top.get("source_name", "N/A")
              source_url = top.get("source_url", "")
              notes = top.get("notes", "")

              if top["kind"] == "campaign_active":
                  title = f"Sugestão de notícia - {top['title']} - campanha em curso"
                  timing = "já está a decorrer"
              elif top["kind"] == "campaign_start":
                  title = f"Sugestão de notícia - {top['title']} - começa em {top['days_until']} dia(s)"
                  timing = f"começa a {top['event_date']}"
              else:
                  title = f"Sugestão de notícia - {top['title']} - em {top['days_until']} dia(s)"
                  timing = f"acontece a {top['event_date']}"

              body = f"""Foi identificado um tema editorial relevante que {timing}.

          **Evento:** {top['title']}
          **Categoria:** {category}
          **Data do evento:** {top['event_date']}
          **Faltam:** {top['days_until']} dia(s)
          **Especialidades:** {specialties}
          **Fonte:** {source_name}
          **URL:** {source_url}
          **Notas:** {notes}

          ### Próximos passos
          - Rever se faz sentido publicar no site
          - Pedir texto e imagem no ChatGPT
          - Adicionar entrada ao `src/data/news.ts`
          - Publicar manualmente no site
          """

              with open(output_path, "a", encoding="utf-8") as f:
                  f.write("has_match=true\n")
                  f.write(f"title<<EOF\n{title}\nEOF\n")
                  f.write(f"body<<EOF\n{body}\nEOF\n")
          else:
              with open(output_path, "a", encoding="utf-8") as f:
                  f.write("has_match=false\n")
          PY

      - name: Create issue
        if: steps.editorial.outputs.has_match == 'true'
        uses: actions/github-script@v7
        env:
          ISSUE_TITLE: ${{ steps.editorial.outputs.title }}
          ISSUE_BODY: ${{ steps.editorial.outputs.body }}
        with:
          script: |
            const title = process.env.ISSUE_TITLE;
            const body = process.env.ISSUE_BODY;

            const { data: issues } = await github.rest.issues.listForRepo({
              owner: context.repo.owner,
              repo: context.repo.repo,
              state: "open",
              per_page: 100
            });

            const alreadyExists = issues.some(issue => issue.title === title);

            if (alreadyExists) {
              core.info(`Issue already exists: ${title}`);
            } else {
              await github.rest.issues.create({
                owner: context.repo.owner,
                repo: context.repo.repo,
                title,
                body
              });
              core.info(`Issue created: ${title}`);
            }
